\name{print.mcp_connection}
\alias{print.mcp_connection}
\title{Print an MCP Connection}
\usage{
\method{print}{mcp_connection}(x, ...)
}
\arguments{
\item{x}{An MCP connection object.}

\item{...}{Unused.}
}
\value{
\code{x}, invisibly. Called for the side effect of printing a
  summary of the connection state and available tools.
}
\description{
S3 print method for MCP connection objects.
}
\examples{
\dontrun{
conn <- mcp_connect(port = 7850)
print(conn)
mcp_close(conn)
}
}
